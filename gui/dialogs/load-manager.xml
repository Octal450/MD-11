<PropertyList>
	
	<name>load-manager</name>
	<layout>vbox</layout>
	
	<nasal>
		<open>
			setprop("/sim/gui/dialogs/load-manager/title", getprop("/sim/aircraft") ~ " Load Manager");
			core.LoadManager.getLoad(); # Populate with current load
			
			setprop("/sim/gui/dialogs/load-manager/mtow-lbs", sprintf("%d", math.round(getprop("/limits/mass-and-balance/maximum-takeoff-mass-lbs"))) ~ " lbs");
			setprop("/sim/gui/dialogs/load-manager/mlw-lbs", sprintf("%d", math.round(getprop("/limits/mass-and-balance/maximum-landing-mass-lbs"))) ~ " lbs");
			setprop("/sim/gui/dialogs/load-manager/mzfw-lbs", sprintf("%d", math.round(getprop("/limits/mass-and-balance/maximum-zero-fuel-mass-lbs"))) ~ " lbs");
			
			setprop("/sim/gui/dialogs/load-manager/gw-lbs", sprintf("%d", math.round(getprop("/systems/load-manager/gw-lbs"))) ~ " lbs");
			setprop("/sim/gui/dialogs/load-manager/zfw-lbs", sprintf("%d", math.round(getprop("/systems/load-manager/zfw-lbs"))) ~ " lbs");
			
			setprop("/sim/gui/dialogs/load-manager/cg-percent-mac", sprintf("%4.1f", math.round(getprop("/systems/load-manager/cg-percent-mac"), 0.1)) ~ "% MAC");
			setprop("/sim/gui/dialogs/load-manager/zfwcg-percent-mac", sprintf("%4.1f", math.round(getprop("/systems/load-manager/zfwcg-percent-mac"), 0.1)) ~ "% MAC");
			
			setprop("/sim/gui/dialogs/load-manager/cg-aft-limit", sprintf("%4.1f", math.round(getprop("/systems/load-manager/cg-aft-limit"), 0.1)) ~ "% MAC");
			setprop("/sim/gui/dialogs/load-manager/cg-fwd-limit", sprintf("%4.1f", math.round(getprop("/systems/load-manager/cg-fwd-limit"), 0.1)) ~ "% MAC");
			setprop("/sim/gui/dialogs/load-manager/zfwcg-aft-limit", sprintf("%4.1f", math.round(getprop("/systems/load-manager/zfwcg-aft-limit"), 0.1)) ~ "% MAC");
			setprop("/sim/gui/dialogs/load-manager/zfwcg-fwd-limit", sprintf("%4.1f", math.round(getprop("/systems/load-manager/zfwcg-fwd-limit"), 0.1)) ~ "% MAC");
			
			var loop = maketimer(0.1, func() {
				setprop("/sim/gui/dialogs/load-manager/gw-lbs", sprintf("%d", math.round(getprop("/systems/load-manager/gw-lbs"))) ~ " lbs");
				setprop("/sim/gui/dialogs/load-manager/zfw-lbs", sprintf("%d", math.round(getprop("/systems/load-manager/zfw-lbs"))) ~ " lbs");
				
				setprop("/sim/gui/dialogs/load-manager/cg-percent-mac", sprintf("%4.1f", math.round(getprop("/systems/load-manager/cg-percent-mac"), 0.1)) ~ "% MAC");
				setprop("/sim/gui/dialogs/load-manager/zfwcg-percent-mac", sprintf("%4.1f", math.round(getprop("/systems/load-manager/zfwcg-percent-mac"), 0.1)) ~ "% MAC");
			
				setprop("/sim/gui/dialogs/load-manager/cg-aft-limit", sprintf("%4.1f", math.round(getprop("/systems/load-manager/cg-aft-limit"), 0.1)) ~ "% MAC");
				setprop("/sim/gui/dialogs/load-manager/cg-fwd-limit", sprintf("%4.1f", math.round(getprop("/systems/load-manager/cg-fwd-limit"), 0.1)) ~ "% MAC");
				setprop("/sim/gui/dialogs/load-manager/zfwcg-aft-limit", sprintf("%4.1f", math.round(getprop("/systems/load-manager/zfwcg-aft-limit"), 0.1)) ~ "% MAC");
				setprop("/sim/gui/dialogs/load-manager/zfwcg-fwd-limit", sprintf("%4.1f", math.round(getprop("/systems/load-manager/zfwcg-fwd-limit"), 0.1)) ~ "% MAC");
			});
			loop.start();
		</open>
		<close>
			loop.stop();
			
			lmTimer.stop();
			lmTimer = nil;
			load_manager_canvas_dlg.del();
			load_manager_canvas_dlg = nil;
			root = nil;
		</close>
	</nasal>
	
