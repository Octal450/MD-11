<system name="MD-11: Core">
	
	<channel name="FDM Rate">
		
		<switch name="position/wow">
			<default value="0"/>
			<test logic="OR" value="1">
				gear/unit[0]/WOW eq 1
				gear/unit[1]/WOW eq 1
				gear/unit[2]/WOW eq 1
			</test>
			<output>/position/wow</output> <!-- Copy to local tree -->
		</switch>
		
		<switch name="aero/alpha-deg-fixed">
			<default value="0"/>
			<test value="aero/alpha-deg">
				gear/unit[0]/WOW eq 0
			</test>
		</switch>
		
		<lag_filter name="aero/alpha-deg-damped">
			<input>aero/alpha-deg-fixed</input>
			<c1>10</c1>
		</lag_filter>
		
		<fcs_function name="position/gear-agl">
			<function>
				<difference>
					<property>/position/altitude-agl-ft</property>
					<value>17.1</value>
				</difference>
			</function>
		</fcs_function>
		
		<lag_filter name="position/gear-agl-ft">
			<input>position/gear-agl</input>
			<c1>20</c1>
			<output>/position/gear-agl-ft</output> <!-- So flight recorder can override it -->
		</lag_filter>
		
		<summer name="inertia/zfw-lbs">
			<input>inertia/weight-lbs</input>
			<input>-propulsion/total-fuel-lbs</input>
		</summer>
		
		<pure_gain name="inertia/weight-kg">
			<input>inertia/weight-lbs</input>
			<gain>0.45359237</gain>
		</pure_gain>
		
		<fcs_function name="inertia/cg-percent-mac">
			<function>
				<product>
					<quotient>
						<difference>
							<product>
								<property>inertia/cg-x-in</property>
								<value>0.0254</value> <!-- Inches to meters -->
							</product>
							<value>0.24116</value> <!-- Offset -->
						</difference>
						<value>7.68</value> <!-- MAC length -->
					</quotient>
					<value>100</value>
				</product>
			</function>
		</fcs_function>
		
		<fcs_function name="inertia/zfwcg-x-in">
			<function>
				<quotient> <!-- Weighted average -->
					<sum>
						<product>
							<property>inertia/empty-weight-lbs</property>
							<property>inertia/empty-weight-x-in</property>
						</product>
						<product>
							<property>inertia/pointmass-weight-lbs[0]</property>
							<property>inertia/pointmass-location-X-inches[0]</property>
						</product>
						<product>
							<property>inertia/pointmass-weight-lbs[1]</property>
							<property>inertia/pointmass-location-X-inches[1]</property>
						</product>
						<product>
							<property>inertia/pointmass-weight-lbs[2]</property>
							<property>inertia/pointmass-location-X-inches[2]</property>
						</product>
						<product>
							<property>inertia/pointmass-weight-lbs[3]</property>
							<property>inertia/pointmass-location-X-inches[3]</property>
						</product>
						<product>
							<property>inertia/pointmass-weight-lbs[4]</property>
							<property>inertia/pointmass-location-X-inches[4]</property>
						</product>
						<product>
							<property>inertia/pointmass-weight-lbs[5]</property>
							<property>inertia/pointmass-location-X-inches[5]</property>
						</product>
					</sum>
					<sum>
						<property>inertia/empty-weight-lbs</property>
						<property>inertia/pointmass-weight-lbs[0]</property>
						<property>inertia/pointmass-weight-lbs[1]</property>
						<property>inertia/pointmass-weight-lbs[2]</property>
						<property>inertia/pointmass-weight-lbs[3]</property>
						<property>inertia/pointmass-weight-lbs[4]</property>
						<property>inertia/pointmass-weight-lbs[5]</property>
					</sum>
				</quotient>
			</function>
		</fcs_function>
		
		<fcs_function name="inertia/zfwcg-percent-mac"> <!-- Remember to match md-11-fms.xml to this -->
			<function>
				<product>
					<quotient>
						<difference>
							<product>
								<property>inertia/zfwcg-x-in</property>
								<value>0.0254</value> <!-- Inches to meters -->
							</product>
							<value>0.24116</value> <!-- Offset -->
						</difference>
						<value>7.68</value> <!-- MAC length -->
					</quotient>
					<value>100</value>
				</product>
			</function>
		</fcs_function>
		
		<switch name="/orientation/track-magnetic-deg-switched">
			<default value="/orientation/heading-magnetic-deg"/>
			<test logic="AND" value="/orientation/track-magnetic-deg">
				/velocities/groundspeed-kt ge 1
			</test>
		</switch>
		
		<switch name="/orientation/track-deg-switched">
			<default value="/orientation/heading-deg"/>
			<test logic="AND" value="/orientation/track-deg">
				/velocities/groundspeed-kt ge 1
			</test>
		</switch>
		
		<summer name="/consumables/fuel/total-fuel-actual"> <!-- Total fuel without the feed pipes -->
			<input>propulsion/tank[0]/contents-lbs</input>
			<input>propulsion/tank[1]/contents-lbs</input>
			<input>propulsion/tank[2]/contents-lbs</input>
			<input>propulsion/tank[3]/contents-lbs</input>
			<input>propulsion/tank[4]/contents-lbs</input>
			<input>propulsion/tank[5]/contents-lbs</input>
			<input>propulsion/tank[6]/contents-lbs</input>
			<input>propulsion/tank[7]/contents-lbs</input>
		</summer>
		
		<switch name="contact/any-wow"> <!-- For failure-bridge.nas -->
			<default value="0"/>
			<test logic="OR" value="1">
				contact/unit[6]/WOW eq 1
				contact/unit[7]/WOW eq 1
				contact/unit[8]/WOW eq 1
				contact/unit[9]/WOW eq 1
				contact/unit[10]/WOW eq 1
				contact/unit[11]/WOW eq 1
				contact/unit[12]/WOW eq 1
				contact/unit[13]/WOW eq 1
				contact/unit[14]/WOW eq 1
				contact/unit[15]/WOW eq 1
				contact/unit[16]/WOW eq 1
				contact/unit[17]/WOW eq 1
				contact/unit[18]/WOW eq 1
			</test>
			<output>contact/any-wow-out</output>
		</switch>
	
	</channel>
	
	<channel name="Execrate 8" execrate="8">
		
		<switch name="/systems/engines/any-engine-on">
			<default value="0"/>
			<test logic="OR" value="1">
				/engines/engine[0]/state eq 3
				/engines/engine[1]/state eq 3
				/engines/engine[2]/state eq 3
			</test>
		</switch>
		
		<switch name="/systems/engines/any-engine-out">
			<default value="0"/>
			<test logic="OR" value="1">
				/engines/engine[0]/state ne 3
				/engines/engine[1]/state ne 3
				/engines/engine[2]/state ne 3
			</test>
		</switch>
		
		<switch name="/systems/engines/multi-engine-out">
			<default value="0"/>
			<test logic="AND" value="1">
				/engines/engine[0]/state ne 3
				/engines/engine[1]/state ne 3
			</test>
			<test logic="AND" value="1">
				/engines/engine[0]/state ne 3
				/engines/engine[2]/state ne 3
			</test>
			<test logic="AND" value="1">
				/engines/engine[1]/state ne 3
				/engines/engine[2]/state ne 3
			</test>
		</switch>
		
		<switch name="/systems/engines/two-engine-on">
			<default value="0"/>
			<test logic="AND" value="1">
				/engines/engine[0]/state eq 3
				/engines/engine[1]/state eq 3
			</test>
			<test logic="AND" value="1">
				/engines/engine[0]/state eq 3
				/engines/engine[2]/state eq 3
			</test>
			<test logic="AND" value="1">
				/engines/engine[1]/state eq 3
				/engines/engine[2]/state eq 3
			</test>
		</switch>
		
		<fcs_function name="/systems/core/blink-fast">
			<function>
				<floor>
					<mod>
						<product>
							<property>sim-time-sec</property>
							<value>3.5</value>
						</product>
						<value>2</value>
					</mod>
				</floor>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/core/blink-med">
			<function>
				<floor>
					<mod>
						<product>
							<property>sim-time-sec</property>
							<value>2.5</value>
						</product>
						<value>2</value>
					</mod>
				</floor>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/core/blink-med-2">
			<function>
				<floor>
					<mod>
						<product>
							<sum>
								<property>sim-time-sec</property>
								<value>1</value>
							</sum>
							<value>2.5</value>
						</product>
						<value>2</value>
					</mod>
				</floor>
			</function>
		</fcs_function>
	
	</channel>
	
	<channel name="Load Manager">
		
		<!-- Fuel Distribution -->
		<!--
			Refueling schedule:
			Load 1, 2, 3 until 5000 in each
			Load 0, 2, 4 so that 0 + 1 = 2 = 3 + 4 until 0 and 4 are full
			Load 1, 2, 3 so that 0 + 1 = 2 = 3 + 4 until 0, 1, 3, 4 are full
			Load 2 until full
			Load 7 so that 7:(5 + 6) with 7.5:1 ratio
			Load 5 until full respecting 7's schedule
			Load 6 until full respecting 7's schedule
		-->
		
		<pure_gain name="/systems/load-manager/fuel/total-fuel"> <!-- Keep synchronized -->
			<input>/systems/load-manager/total-fuel</input>
			<gain>1.0</gain>
		</pure_gain>
		
		<fcs_function name="/systems/load-manager/fuel/tank[0]"> <!-- Tank 1 Outboard -->
			<function>
				<difference>
					<quotient>
						<property>/systems/load-manager/fuel/total-fuel</property>
						<value>3</value>
					</quotient>
					<value>5000</value>
				</difference>
			</function>
			<clipto>
				<min>0</min>
				<max>/systems/load-manager/tank-capacity[0]</max>
			</clipto>
		</fcs_function>
		
		<fcs_function name="/systems/load-manager/fuel/tank[4]"> <!-- Tank 3 Outboard -->
			<function>
				<difference>
					<quotient>
						<property>/systems/load-manager/fuel/total-fuel</property>
						<value>3</value>
					</quotient>
					<value>5000</value>
				</difference>
			</function>
			<clipto>
				<min>0</min>
				<max>/systems/load-manager/tank-capacity[4]</max>
			</clipto>
		</fcs_function>
		
		<fcs_function name="/systems/load-manager/fuel/tank[1]"> <!-- Tank 1 Inboard -->
			<function>
				<min>
					<quotient> <!-- 1 = 2 = 3 (low fuel) -->
						<property>/systems/load-manager/fuel/total-fuel</property>
						<value>3</value>
					</quotient>
					<difference> <!-- 0 + 1 = 2 -->
						<property>/systems/load-manager/fuel/tank[2]</property>
						<property>/systems/load-manager/fuel/tank[0]</property>
					</difference>
				</min>
			</function>
			<clipto>
				<min>0</min>
				<max>/systems/load-manager/tank-capacity[1]</max>
			</clipto>
		</fcs_function>
		
		<fcs_function name="/systems/load-manager/fuel/tank[3]"> <!-- Tank 3 Inboard -->
			<function>
				<min>
					<quotient> <!-- 1 = 2 = 3 (low fuel) -->
						<property>/systems/load-manager/fuel/total-fuel</property>
						<value>3</value>
					</quotient>
					<difference> <!-- 3 + 4 = 2 -->
						<property>/systems/load-manager/fuel/tank[2]</property>
						<property>/systems/load-manager/fuel/tank[4]</property>
					</difference>
				</min>
			</function>
			<clipto>
				<min>0</min>
				<max>/systems/load-manager/tank-capacity[3]</max>
			</clipto>
		</fcs_function>
		
		<fcs_function name="/systems/load-manager/fuel/tank[2]"> <!-- Tank 2 -->
			<function>
				<max>
					<quotient> <!-- Balanced -->
						<property>/systems/load-manager/fuel/total-fuel</property>
						<value>3</value>
					</quotient>
					<difference> <!-- Tanks 1 and 3 full -->
						<property>/systems/load-manager/fuel/total-fuel</property>
						<property>/systems/load-manager/fuel/tank[0]</property>
						<property>/systems/load-manager/fuel/tank[1]</property>
						<property>/systems/load-manager/fuel/tank[3]</property>
						<property>/systems/load-manager/fuel/tank[4]</property>
					</difference>
				</max>
			</function>
			<clipto>
				<min>0</min>
				<max>/systems/load-manager/tank-capacity[2]</max>
			</clipto>
		</fcs_function>
		
		<!-- Aux and Tail tanks are filled at a 7.5:1 ratio -->
		<fcs_function name="/systems/load-manager/fuel/tank[7]"> <!-- Tail Tank -->
			<function>
				<quotient>
					<difference>
						<property>/systems/load-manager/fuel/total-fuel</property>
						<property>/systems/load-manager/fuel/tank[0]</property>
						<property>/systems/load-manager/fuel/tank[1]</property>
						<property>/systems/load-manager/fuel/tank[2]</property>
						<property>/systems/load-manager/fuel/tank[3]</property>
						<property>/systems/load-manager/fuel/tank[4]</property>
					</difference>
					<value>8.5</value>
				</quotient>
			</function>
			<clipto>
				<min>0</min>
				<max>/systems/load-manager/tank-capacity[7]</max>
			</clipto>
		</fcs_function>
		
		<fcs_function name="/systems/load-manager/fuel/tank[5]"> <!-- Upper Aux Tank -->
			<function>
				<difference>
					<property>/systems/load-manager/fuel/total-fuel</property>
					<property>/systems/load-manager/fuel/tank[0]</property>
					<property>/systems/load-manager/fuel/tank[1]</property>
					<property>/systems/load-manager/fuel/tank[2]</property>
					<property>/systems/load-manager/fuel/tank[3]</property>
					<property>/systems/load-manager/fuel/tank[4]</property>
					<property>/systems/load-manager/fuel/tank[7]</property>
				</difference>
			</function>
			<clipto>
				<min>0</min>
				<max>/systems/load-manager/tank-capacity[5]</max>
			</clipto>
		</fcs_function>
		
		<fcs_function name="/systems/load-manager/fuel/tank[6]"> <!-- Lower Aux Tank -->
			<function>
				<difference>
					<property>/systems/load-manager/fuel/total-fuel</property>
					<property>/systems/load-manager/fuel/tank[0]</property>
					<property>/systems/load-manager/fuel/tank[1]</property>
					<property>/systems/load-manager/fuel/tank[2]</property>
					<property>/systems/load-manager/fuel/tank[3]</property>
					<property>/systems/load-manager/fuel/tank[4]</property>
					<property>/systems/load-manager/fuel/tank[5]</property>
					<property>/systems/load-manager/fuel/tank[7]</property>
				</difference>
			</function>
			<clipto>
				<min>0</min>
				<max>/systems/load-manager/tank-capacity[6]</max>
			</clipto>
		</fcs_function>
		
		<summer name="/systems/load-manager/fuel/total-calc">
			<input>/systems/load-manager/fuel/tank[0]</input>
			<input>/systems/load-manager/fuel/tank[1]</input>
			<input>/systems/load-manager/fuel/tank[2]</input>
			<input>/systems/load-manager/fuel/tank[3]</input>
			<input>/systems/load-manager/fuel/tank[4]</input>
			<input>/systems/load-manager/fuel/tank[5]</input>
			<input>/systems/load-manager/fuel/tank[6]</input>
			<input>/systems/load-manager/fuel/tank[7]</input>
		</summer>
		
		<!-- Payload -->
		<switch name="/systems/load-manager/weight[0]">
			<default value="/systems/load-manager/weight-p[0]"/>
			<test value="/systems/load-manager/weight-f[0]">
				/options/freighter eq 1
			</test>
		</switch>
		
		<switch name="/systems/load-manager/weight[1]">
			<default value="/systems/load-manager/weight-p[1]"/>
			<test value="/systems/load-manager/weight-f[1]">
				/options/freighter eq 1
			</test>
		</switch>
		
		<switch name="/systems/load-manager/weight[2]">
			<default value="/systems/load-manager/weight-p[2]"/>
			<test value="/systems/load-manager/weight-f[2]">
				/options/freighter eq 1
			</test>
		</switch>
		
		<!-- Weights and CGs -->
		<summer name="/systems/load-manager/zfw-lbs">
			<input>inertia/empty-weight-lbs</input>
			<input>/systems/load-manager/weight[0]</input>
			<input>/systems/load-manager/weight[1]</input>
			<input>/systems/load-manager/weight[2]</input>
			<input>/systems/load-manager/weight[3]</input>
			<input>/systems/load-manager/weight[4]</input>
			<input>/systems/load-manager/weight[5]</input>
		</summer>
		
		<summer name="/systems/load-manager/gw-lbs">
			<input>/systems/load-manager/zfw-lbs</input>
			<input>/systems/load-manager/fuel/total-fuel</input>
		</summer>
		
		<fcs_function name="/systems/load-manager/zfwcg-x-in">
			<function>
				<quotient> <!-- Weighted average -->
					<sum>
						<product>
							<property>inertia/empty-weight-lbs</property>
							<property>inertia/empty-weight-x-in</property>
						</product>
						<product>
							<property>/systems/load-manager/weight[0]</property>
							<property>inertia/pointmass-location-X-inches[0]</property>
						</product>
						<product>
							<property>/systems/load-manager/weight[1]</property>
							<property>inertia/pointmass-location-X-inches[1]</property>
						</product>
						<product>
							<property>/systems/load-manager/weight[2]</property>
							<property>inertia/pointmass-location-X-inches[2]</property>
						</product>
						<product>
							<property>/systems/load-manager/weight[3]</property>
							<property>inertia/pointmass-location-X-inches[3]</property>
						</product>
						<product>
							<property>/systems/load-manager/weight[4]</property>
							<property>inertia/pointmass-location-X-inches[4]</property>
						</product>
						<product>
							<property>/systems/load-manager/weight[5]</property>
							<property>inertia/pointmass-location-X-inches[5]</property>
						</product>
					</sum>
					<property>/systems/load-manager/zfw-lbs</property>
				</quotient>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/load-manager/zfwcg-percent-mac">
			<function>
				<product>
					<quotient>
						<difference>
							<product>
								<property>/systems/load-manager/zfwcg-x-in</property>
								<value>0.0254</value> <!-- Inches to meters -->
							</product>
							<value>0.24116</value> <!-- Offset -->
						</difference>
						<value>7.68</value> <!-- MAC length -->
					</quotient>
					<value>100</value>
				</product>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/load-manager/zfw-lbs-limited">
			<function>
				<min>
					<property>/limits/mass-and-balance/maximum-zero-fuel-mass-lbs</property>
					<property>/systems/load-manager/zfw-lbs</property>
				</min>
			</function>
		</fcs_function>
		
		<switch name="/systems/load-manager/zfwcg-aft-limit-sel">
			<default value="0"/>
			<test value="2">
				/systems/load-manager/gw-lbs ge 630499.5
			</test>
			<test value="1">
				/systems/load-manager/gw-lbs ge 619999.5
			</test>
		</switch>
		
		<fcs_function name="/systems/load-manager/zfwcg-aft-limit"> <!-- From FCOM -->
			<function>
				<table>
					<independentVar lookup="row">/systems/load-manager/zfw-lbs-limited</independentVar>
					<independentVar lookup="column">zero</independentVar> <!-- Take advantage of the table lookup to interpolate -->
					<independentVar lookup="table">/systems/load-manager/zfwcg-aft-limit-sel</independentVar>
					<tableData breakPoint="0">
						        0     1
						242100  31.0  31.0
						260500  31.2  31.2
						324100  31.8  31.8
						365800  30.1  30.1
						451300  28.8  28.8
						461300  28.2  28.2
					</tableData>
					<tableData breakPoint="1">
						        0     1
						242100  31.0  31.0
						260500  31.2  31.2
						324100  31.8  31.8
						335900  28.7  28.7
						383600  27.8  27.8
						451300  26.9  26.9
						461300  26.8  26.8
					</tableData>
					<tableData breakPoint="2">
						        0     1
						242100  31.0  31.0
						260500  31.2  31.2
						324100  31.8  31.8
						348400  25.7  25.7
						400000  25.0  25.0
						451300  24.6  24.6
						461300  24.5  24.5
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/load-manager/zfwcg-fwd-limit"> <!-- From FCOM -->
			<function>
				<table>
					<independentVar lookup="row">/systems/load-manager/zfw-lbs-limited</independentVar>
					<tableData>
						380000  12.0
						451300  13.2
						461300  13.4
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/load-manager/cg-x-in">
			<function>
				<quotient> <!-- Weighted average -->
					<sum>
						<product>
							<property>inertia/empty-weight-lbs</property>
							<property>inertia/empty-weight-x-in</property>
						</product>
						<product>
							<property>/systems/load-manager/weight[0]</property>
							<property>inertia/pointmass-location-X-inches[0]</property>
						</product>
