		<fcs_function name="/systems/pneumatics/hvac/conditioned-air-temp-cmd">
			<function>
				<ifthen>
					<gt>
						<sum>
							<property>/systems/pneumatics/hvac/pack-temp/pack-1-flow-factor</property>
							<property>/systems/pneumatics/hvac/pack-temp/pack-2-flow-factor</property>
							<property>/systems/pneumatics/hvac/pack-temp/pack-3-flow-factor</property>
						</sum>
						<value>0</value>
					</gt>
					<quotient> <!-- Weighted average -->
						<sum>
							<product>
								<property>/systems/pneumatics/hvac/pack-temp/pack-1-actuator</property>
								<property>/systems/pneumatics/hvac/pack-temp/pack-1-flow-factor</property>
							</product>
							<product>
								<property>/systems/pneumatics/hvac/pack-temp/pack-2-actuator</property>
								<property>/systems/pneumatics/hvac/pack-temp/pack-2-flow-factor</property>
							</product>
							<product>
								<property>/systems/pneumatics/hvac/pack-temp/pack-3-actuator</property>
								<property>/systems/pneumatics/hvac/pack-temp/pack-3-flow-factor</property>
							</product>
						</sum>
						<sum>
							<property>/systems/pneumatics/hvac/pack-temp/pack-1-flow-factor</property>
							<property>/systems/pneumatics/hvac/pack-temp/pack-2-flow-factor</property>
							<property>/systems/pneumatics/hvac/pack-temp/pack-3-flow-factor</property>
						</sum>
					</quotient>
					<avg> <!-- There's no flow, so just average the ambiants -->
						<property>/systems/pneumatics/hvac/pack-temp/pack-1-actuator</property>
						<property>/systems/pneumatics/hvac/pack-temp/pack-2-actuator</property>
						<property>/systems/pneumatics/hvac/pack-temp/pack-3-actuator</property>
					</avg>
				</ifthen>
			</function>
		</fcs_function>
		
		<lag_filter name="/systems/pneumatics/hvac/conditioned-air-temp">
			<input>/systems/pneumatics/hvac/conditioned-air-temp-cmd</input>
			<c1>0.4</c1>
		</lag_filter>
		
