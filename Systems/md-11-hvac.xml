<?xml version="1.0"?>

<!-- McDonnell Douglas MD-11 HVAC -->
<!-- Copyright (c) 2026 Josh Davidson (Octal450) -->

<system name="MD-11: HVAC"> <!-- The airplane is calibrated in Fahrenheit since it's American designed, so that's what I'll use here -->
	
	<property value="75">/systems/pneumatics/hvac/cabin-aft-temp</property>
	<property value="75">/systems/pneumatics/hvac/cabin-fwd-temp</property>
	<property value="75">/systems/pneumatics/hvac/cabin-mid-temp</property>
	<property value="68">/systems/pneumatics/hvac/cargo-aft-temp</property>
	<property value="70">/systems/pneumatics/hvac/cargo-fwd-temp</property>
	<property value="68">/systems/pneumatics/hvac/cargo-mid-temp</property>
	<property value="75">/systems/pneumatics/hvac/cockpit-temp</property>
	
	<!--
	Cargo Mid zone is heated but not cooled or ventilated
	Freighters have different upper zones: Cockpit, Courier, and Cargo. The Courier zone is mapped to Cabin Fwd, and the Cargo zone is mapped to Cabin Mid.
	Cabin Aft simply mirrors Cabin Mid to "simulate" a larger zone, which corrects how it affects the Courier (Cabin Fwd) zone.
	-->
	
	<channel name="HVAC Logic">
		
		<!-- Temperature Targets -->
		<fcs_function name="/systems/pneumatics/hvac/cockpit-target">
			<function>
				<table>
					<independentVar lookup="row">/controls/pneumatics/cockpit-temp</independentVar> <!-- 0 to 0.85 -->
					<tableData>
						0.00   0
						0.05  65
						0.85  85
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/cabin-fwd-target">
			<function>
				<table>
					<independentVar lookup="row">/controls/pneumatics/cabin-fwd-temp</independentVar> <!-- 0 to 0.85 -->
					<tableData>
						0.00   0
						0.05  65
						0.85  85
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/cabin-mid-target">
			<function>
				<table>
					<independentVar lookup="row">/controls/pneumatics/cabin-mid-temp</independentVar> <!-- 0 to 0.85 -->
					<tableData>
						0.00   0
						0.05  65
						0.85  85
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/cabin-aft-target">
			<function>
				<ifthen>
					<eq>
						<property>/options/freighter</property>
						<value>1</value>
					</eq>
					<property>/systems/pneumatics/hvac/cabin-mid-target</property> <!-- Freighter doesn't have aft, this makes it "invisible" -->
					<table>
						<independentVar lookup="row">/controls/pneumatics/cabin-aft-temp</independentVar> <!-- 0 to 0.85 -->
						<tableData>
							0.00   0
							0.05  65
							0.85  85
						</tableData>
					</table>
				</ifthen>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/cargo-fwd-target">
			<function>
				<table>
					<independentVar lookup="row">/controls/pneumatics/cargo-fwd-temp</independentVar> <!-- 0 to 1 -->
					<tableData>
						0.0   0
						0.5  40
						1.0  70
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/cargo-aft-target">
			<function>
				<table>
					<independentVar lookup="row">/controls/pneumatics/cargo-aft-temp</independentVar> <!-- 0 to 0.75 -->
					<tableData>
						0.00   0
						0.05  40
						0.75  96
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<!-- Switched Temperature Targets -->
		<switch name="/systems/pneumatics/hvac/cockpit-target-switched">
			<default value="/systems/pneumatics/hvac/cockpit-temp"/>
			<test value="/systems/pneumatics/hvac/cockpit-target">
				/systems/pneumatics/hvac/cockpit-target ge 60
			</test>
		</switch>
		
		<switch name="/systems/pneumatics/hvac/cabin-fwd-target-switched">
			<default value="/systems/pneumatics/hvac/cabin-fwd-temp"/>
			<test value="/systems/pneumatics/hvac/cabin-fwd-target">
				/systems/pneumatics/hvac/cabin-fwd-target ge 60
			</test>
		</switch>
		
		<switch name="/systems/pneumatics/hvac/cabin-mid-target-switched">
			<default value="/systems/pneumatics/hvac/cabin-mid-temp"/>
			<test value="/systems/pneumatics/hvac/cabin-mid-target">
				/systems/pneumatics/hvac/cabin-mid-target ge 60
			</test>
		</switch>
		
		<switch name="/systems/pneumatics/hvac/cabin-aft-target-switched">
			<default value="/systems/pneumatics/hvac/cabin-aft-temp"/>
			<test value="/systems/pneumatics/hvac/cabin-aft-target">
				/systems/pneumatics/hvac/cabin-aft-target ge 60
			</test>
		</switch>
		
		<switch name="/systems/pneumatics/hvac/cargo-fwd-target-switched">
			<default value="/systems/pneumatics/hvac/cargo-fwd-temp"/>
			<test value="/systems/pneumatics/hvac/cargo-fwd-target">
				/systems/pneumatics/hvac/cargo-fwd-target ge 35
			</test>
		</switch>
		
		<switch name="/systems/pneumatics/hvac/cargo-aft-target-switched">
			<default value="/systems/pneumatics/hvac/cargo-aft-temp"/>
			<test value="/systems/pneumatics/hvac/cargo-aft-target">
				/systems/pneumatics/hvac/cargo-aft-target ge 35
			</test>
		</switch>
		
		<!-- Temperature Error -->
		<summer name="/systems/pneumatics/hvac/cockpit-error">
			<input>/systems/pneumatics/hvac/cockpit-target-switched</input>
			<input>-/systems/pneumatics/hvac/cockpit-temp</input>
		</summer>
		
		<summer name="/systems/pneumatics/hvac/cabin-fwd-error">
			<input>/systems/pneumatics/hvac/cabin-fwd-target-switched</input>
			<input>-/systems/pneumatics/hvac/cabin-fwd-temp</input>
		</summer>
		
		<summer name="/systems/pneumatics/hvac/cabin-mid-error">
			<input>/systems/pneumatics/hvac/cabin-mid-target-switched</input>
			<input>-/systems/pneumatics/hvac/cabin-mid-temp</input>
		</summer>
		
		<summer name="/systems/pneumatics/hvac/cabin-aft-error">
			<input>/systems/pneumatics/hvac/cabin-aft-target-switched</input>
			<input>-/systems/pneumatics/hvac/cabin-aft-temp</input>
		</summer>
		
		<summer name="/systems/pneumatics/hvac/cargo-fwd-error">
			<input>/systems/pneumatics/hvac/cargo-fwd-target-switched</input>
			<input>-/systems/pneumatics/hvac/cargo-fwd-temp</input>
		</summer>
		
		<summer name="/systems/pneumatics/hvac/cargo-aft-error">
			<input>/systems/pneumatics/hvac/cargo-aft-target-switched</input>
			<input>-/systems/pneumatics/hvac/cargo-aft-temp</input>
		</summer>
		
		<fcs_function name="/systems/pneumatics/hvac/coldest-cabin-error">
			<function>
				<min>
					<property>/systems/pneumatics/hvac/cabin-aft-error</property>
					<property>/systems/pneumatics/hvac/cabin-mid-error</property>
					<property>/systems/pneumatics/hvac/cabin-fwd-error</property>
					<property>/systems/pneumatics/hvac/cockpit-error</property>
				</min>
			</function>
		</fcs_function>
		
		<!-- Pack Temperature Targets -->
		<!-- This is complex because the ECS controls which packs respond based on which zones have error, and accounts for inoperative packs -->
		<switch name="/systems/pneumatics/hvac/pack-1-flowing">
			<default value="1"/>
			<test value="0">
				/systems/pneumatics/pack-1-flow lt 10
			</test>
		</switch>
		
		<switch name="/systems/pneumatics/hvac/pack-2-flowing">
			<default value="1"/>
			<test value="0">
				/systems/pneumatics/pack-2-flow lt 10
			</test>
		</switch>
		
		<switch name="/systems/pneumatics/hvac/pack-3-flowing">
			<default value="1"/>
			<test value="0">
				/systems/pneumatics/pack-3-flow lt 10
			</test>
		</switch>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-1-target-input">
			<function>
				<min>
					<property>/systems/pneumatics/hvac/cockpit-target-switched</property>
					<property>/systems/pneumatics/hvac/cabin-fwd-target-switched</property>
					<ifthen>
						<and>
							<eq>
								<property>/systems/pneumatics/hvac/pack-2-flowing</property>
								<value>0</value>
							</eq>
							<eq>
								<property>/systems/pneumatics/hvac/pack-3-flowing</property>
								<value>0</value>
							</eq>
						</and>
						<property>/systems/pneumatics/hvac/cabin-mid-target-switched</property>
						<value>1000</value> <!-- Irrelevant -->
					</ifthen>
					<ifthen>
						<and>
							<eq>
								<property>/systems/pneumatics/hvac/pack-2-flowing</property>
								<value>0</value>
							</eq>
							<eq>
								<property>/systems/pneumatics/hvac/pack-3-flowing</property>
								<value>0</value>
							</eq>
						</and>
						<property>/systems/pneumatics/hvac/cabin-aft-target-switched</property>
						<value>1000</value> <!-- Irrelevant -->
					</ifthen>
				</min>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-1-error-input">
			<function>
				<min>
					<property>/systems/pneumatics/hvac/cockpit-error</property>
					<property>/systems/pneumatics/hvac/cabin-fwd-error</property>
					<ifthen>
						<and>
							<eq>
								<property>/systems/pneumatics/hvac/pack-2-flowing</property>
								<value>0</value>
							</eq>
							<eq>
								<property>/systems/pneumatics/hvac/pack-3-flowing</property>
								<value>0</value>
							</eq>
						</and>
						<property>/systems/pneumatics/hvac/cabin-mid-error</property>
						<value>1000</value> <!-- Irrelevant -->
					</ifthen>
					<ifthen>
						<and>
							<eq>
								<property>/systems/pneumatics/hvac/pack-2-flowing</property>
								<value>0</value>
							</eq>
							<eq>
								<property>/systems/pneumatics/hvac/pack-3-flowing</property>
								<value>0</value>
							</eq>
						</and>
						<property>/systems/pneumatics/hvac/cabin-aft-error</property>
						<value>1000</value> <!-- Irrelevant -->
					</ifthen>
				</min>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-2-target-input">
			<function>
				<min>
					<property>/systems/pneumatics/hvac/cabin-fwd-target-switched</property>
					<property>/systems/pneumatics/hvac/cabin-mid-target-switched</property>
					<ifthen>
						<eq>
							<property>/systems/pneumatics/hvac/pack-1-flowing</property>
							<value>0</value>
						</eq>
						<property>/systems/pneumatics/hvac/cockpit-target-switched</property>
						<value>1000</value> <!-- Irrelevant -->
					</ifthen>
					<ifthen>
						<eq>
							<property>/systems/pneumatics/hvac/pack-3-flowing</property>
							<value>0</value>
						</eq>
						<property>/systems/pneumatics/hvac/cabin-aft-target-switched</property>
						<value>1000</value> <!-- Irrelevant -->
					</ifthen>
				</min>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-2-error-input">
			<function>
				<min>
					<property>/systems/pneumatics/hvac/cabin-fwd-error</property>
					<property>/systems/pneumatics/hvac/cabin-mid-error</property>
					<ifthen>
						<eq>
							<property>/systems/pneumatics/hvac/pack-1-flowing</property>
							<value>0</value>
						</eq>
						<property>/systems/pneumatics/hvac/cockpit-error</property>
						<value>1000</value> <!-- Irrelevant -->
					</ifthen>
					<ifthen>
						<eq>
							<property>/systems/pneumatics/hvac/pack-3-flowing</property>
							<value>0</value>
						</eq>
						<property>/systems/pneumatics/hvac/cabin-aft-error</property>
						<value>1000</value> <!-- Irrelevant -->
					</ifthen>
				</min>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-3-target-input">
			<function>
				<min>
					<property>/systems/pneumatics/hvac/cabin-mid-target-switched</property>
					<property>/systems/pneumatics/hvac/cabin-aft-target-switched</property>
					<ifthen>
						<and>
							<eq>
								<property>/systems/pneumatics/hvac/pack-1-flowing</property>
								<value>0</value>
							</eq>
							<eq>
								<property>/systems/pneumatics/hvac/pack-2-flowing</property>
								<value>0</value>
							</eq>
						</and>
						<property>/systems/pneumatics/hvac/cockpit-target-switched</property>
						<value>1000</value> <!-- Irrelevant -->
					</ifthen>
					<ifthen>
						<and>
							<eq>
								<property>/systems/pneumatics/hvac/pack-1-flowing</property>
								<value>0</value>
							</eq>
							<eq>
								<property>/systems/pneumatics/hvac/pack-2-flowing</property>
								<value>0</value>
							</eq>
						</and>
						<property>/systems/pneumatics/hvac/cabin-fwd-target-switched</property>
						<value>1000</value> <!-- Irrelevant -->
					</ifthen>
				</min>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-3-error-input">
			<function>
				<min>
					<property>/systems/pneumatics/hvac/cabin-mid-error</property>
					<property>/systems/pneumatics/hvac/cabin-aft-error</property>
					<ifthen>
						<and>
							<eq>
								<property>/systems/pneumatics/hvac/pack-1-flowing</property>
								<value>0</value>
							</eq>
							<eq>
								<property>/systems/pneumatics/hvac/pack-2-flowing</property>
								<value>0</value>
							</eq>
						</and>
						<property>/systems/pneumatics/hvac/cockpit-error</property>
						<value>1000</value> <!-- Irrelevant -->
					</ifthen>
					<ifthen>
						<and>
							<eq>
								<property>/systems/pneumatics/hvac/pack-1-flowing</property>
								<value>0</value>
							</eq>
							<eq>
								<property>/systems/pneumatics/hvac/pack-2-flowing</property>
								<value>0</value>
							</eq>
						</and>
						<property>/systems/pneumatics/hvac/cabin-fwd-error</property>
						<value>1000</value> <!-- Irrelevant -->
					</ifthen>
				</min>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-1-target">
			<function>
				<sum>
					<property>/systems/pneumatics/hvac/pack-temp/pack-1-target-input</property>
					<table>
						<independentVar lookup="row">/systems/pneumatics/hvac/pack-temp/pack-1-error-input</independentVar>
						<tableData>
							-5 -9
							 0 -2
							 5  5
						</tableData>
					</table>
				</sum>
			</function>
			<clipto>
				<min>55</min>
				<max>95</max>
			</clipto>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-2-target">
			<function>
				<sum>
					<property>/systems/pneumatics/hvac/pack-temp/pack-2-target-input</property>
					<table>
						<independentVar lookup="row">/systems/pneumatics/hvac/pack-temp/pack-2-error-input</independentVar>
						<tableData>
							-5 -9.6
							 0 -2.6
							 5  4.4
						</tableData>
					</table>
				</sum>
			</function>
			<clipto>
				<min>55</min>
				<max>95</max>
			</clipto>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-3-target">
			<function>
				<sum>
					<property>/systems/pneumatics/hvac/pack-temp/pack-3-target-input</property>
					<table>
						<independentVar lookup="row">/systems/pneumatics/hvac/pack-temp/pack-3-error-input</independentVar>
						<tableData>
							-5 -9.8
							 0 -2.8
							 5  4.2
						</tableData>
					</table>
				</sum>
			</function>
			<clipto>
				<min>55</min>
				<max>95</max>
			</clipto>
		</fcs_function>
		
		<!-- Pack Temperatures -->
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-1-cmd">
			<function>
				<interpolate1d>
					<property>/systems/pneumatics/pack-1-flow</property>
					<value>0</value><property>propulsion/tat-c</property>
					<value>10</value><min>
						<property>/systems/pneumatics/temp/bleed-1</property>
						<property>/systems/pneumatics/hvac/pack-temp/pack-1-target</property>
					</min>
				</interpolate1d>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-1-incr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-1-flow</independentVar>
					<tableData>
						 0  0.1
						10  4.0
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-1-decr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-1-flow</independentVar>
					<tableData>
						 0  0.1
						10  3.0
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<actuator name="/systems/pneumatics/hvac/pack-temp/pack-1-actuator">
			<input>/systems/pneumatics/hvac/pack-temp/pack-1-cmd</input>
			<rate_limit sense="incr">/systems/pneumatics/hvac/pack-temp/pack-1-incr-rate</rate_limit>
			<rate_limit sense="decr">/systems/pneumatics/hvac/pack-temp/pack-1-decr-rate</rate_limit>
		</actuator>
		
		<lag_filter name="/systems/pneumatics/hvac/pack-temp/pack-1">
			<input>/systems/pneumatics/hvac/pack-temp/pack-1-actuator</input>
			<c1>0.4</c1>
		</lag_filter>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-2-cmd">
			<function>
				<interpolate1d>
					<property>/systems/pneumatics/pack-2-flow</property>
					<value>0</value><property>propulsion/tat-c</property>
					<value>10</value><min>
						<property>/systems/pneumatics/temp/bleed-2</property>
						<property>/systems/pneumatics/hvac/pack-temp/pack-2-target</property>
					</min>
				</interpolate1d>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-2-incr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-2-flow</independentVar>
					<tableData>
						 0  0.1
						10  4.0
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-2-decr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-2-flow</independentVar>
					<tableData>
						 0  0.1
						10  3.0
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<actuator name="/systems/pneumatics/hvac/pack-temp/pack-2-actuator">
			<input>/systems/pneumatics/hvac/pack-temp/pack-2-cmd</input>
			<rate_limit sense="incr">/systems/pneumatics/hvac/pack-temp/pack-2-incr-rate</rate_limit>
			<rate_limit sense="decr">/systems/pneumatics/hvac/pack-temp/pack-2-decr-rate</rate_limit>
		</actuator>
		
		<lag_filter name="/systems/pneumatics/hvac/pack-temp/pack-2">
			<input>/systems/pneumatics/hvac/pack-temp/pack-2-actuator</input>
			<c1>0.4</c1>
		</lag_filter>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-3-cmd">
			<function>
				<interpolate1d>
					<property>/systems/pneumatics/pack-3-flow</property>
					<value>0</value><property>propulsion/tat-c</property>
					<value>10</value><min>
						<property>/systems/pneumatics/temp/bleed-3</property>
						<property>/systems/pneumatics/hvac/pack-temp/pack-3-target</property>
					</min>
				</interpolate1d>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-3-incr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-3-flow</independentVar>
					<tableData>
						 0  0.1
						10  4.0
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-3-decr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-3-flow</independentVar>
					<tableData>
						 0  0.1
						10  3.0
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<actuator name="/systems/pneumatics/hvac/pack-temp/pack-3-actuator">
			<input>/systems/pneumatics/hvac/pack-temp/pack-3-cmd</input>
			<rate_limit sense="incr">/systems/pneumatics/hvac/pack-temp/pack-3-incr-rate</rate_limit>
			<rate_limit sense="decr">/systems/pneumatics/hvac/pack-temp/pack-3-decr-rate</rate_limit>
		</actuator>
		
		<lag_filter name="/systems/pneumatics/hvac/pack-temp/pack-3">
			<input>/systems/pneumatics/hvac/pack-temp/pack-3-actuator</input>
			<c1>0.4</c1>
		</lag_filter>
		
		<!-- Conditioned Air Manifold Temperature -->
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-1-flow-factor">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-1-flow</independentVar>
					<tableData>
						 0  0
						10  1
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp/pack-2-flow-factor">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-2-flow</independentVar>
