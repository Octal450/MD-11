<system name="MD-11: HVAC">
	
	<property value="75">/systems/pneumatics/hvac/cabin-aft-temp</property>
	<property value="75">/systems/pneumatics/hvac/cabin-fwd-temp</property>
	<property value="75">/systems/pneumatics/hvac/cabin-mid-temp</property>
	<property value="68">/systems/pneumatics/hvac/cargo-aft-temp</property>
	<property value="70">/systems/pneumatics/hvac/cargo-fwd-temp</property>
	<property value="68">/systems/pneumatics/hvac/cargo-mid-temp</property>
	<property value="75">/systems/pneumatics/hvac/cockpit-temp</property>
	
	<!--
	Cargo Mid zone is heated but not cooled or ventilated
	Freighters have different upper zones: Cockpit, Courier, and Cargo. The Courier zone is mapped to Cabin Fwd, and the Cargo zone is mapped to Cabin Mid.
	Cabin Aft simply mirrors Cabin Mid to "simulate" a larger zone, which corrects how it affects the Courier (Cabin Fwd) zone.
	-->
	
	<channel name="HVAC Logic"> <!-- The airplane is calibrated in Fahrenheit since it's American designed, so that's what I'll use here -->
		
		<summer name="/systems/pneumatics/hvac/pack-flow">
			<input>/systems/pneumatics/pack-1-flow</input>
			<input>/systems/pneumatics/pack-2-flow</input>
			<input>/systems/pneumatics/pack-3-flow</input>
		</summer>
		
		<!-- Temperature Targets -->
		<fcs_function name="/systems/pneumatics/hvac/cockpit-target">
			<function>
				<table>
					<independentVar lookup="row">/controls/pneumatics/cockpit-temp</independentVar> <!-- 0 to 0.85 -->
					<tableData>
						0.00   0
						0.05  65
						0.85  85
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/cabin-fwd-target">
			<function>
				<table>
					<independentVar lookup="row">/controls/pneumatics/cabin-fwd-temp</independentVar> <!-- 0 to 0.85 -->
					<tableData>
						0.00   0
						0.05  65
						0.85  85
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/cabin-mid-target">
			<function>
				<table>
					<independentVar lookup="row">/controls/pneumatics/cabin-mid-temp</independentVar> <!-- 0 to 0.85 -->
					<tableData>
						0.00   0
						0.05  65
						0.85  85
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/cabin-aft-target">
			<function>
				<table>
					<independentVar lookup="row">/controls/pneumatics/cabin-aft-temp</independentVar> <!-- 0 to 0.85 -->
					<tableData>
						0.00   0
						0.05  65
						0.85  85
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/cargo-fwd-target">
			<function>
				<table>
					<independentVar lookup="row">/controls/pneumatics/cargo-fwd-temp</independentVar> <!-- 0 to 1 -->
					<tableData>
						0.0   0
						0.5  40
						1.0  70
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/cargo-aft-target">
			<function>
				<table>
					<independentVar lookup="row">/controls/pneumatics/cargo-aft-temp</independentVar> <!-- 0 to 0.75 -->
					<tableData>
						0.00   0
						0.05  40
						0.75  96
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<!-- Switched Temperature Targets -->
		<switch name="/systems/pneumatics/hvac/cockpit-target-switched">
			<default value="/systems/pneumatics/hvac/cockpit-temp"/>
			<test value="/systems/pneumatics/hvac/cockpit-target">
				/systems/pneumatics/hvac/cockpit-target ge 60
			</test>
		</switch>
		
		<switch name="/systems/pneumatics/hvac/cabin-fwd-target-switched">
			<default value="/systems/pneumatics/hvac/cabin-fwd-temp"/>
			<test value="/systems/pneumatics/hvac/cabin-fwd-target">
				/systems/pneumatics/hvac/cabin-fwd-target ge 60
			</test>
		</switch>
		
		<switch name="/systems/pneumatics/hvac/cabin-mid-target-switched">
			<default value="/systems/pneumatics/hvac/cabin-mid-temp"/>
			<test value="/systems/pneumatics/hvac/cabin-mid-target">
				/systems/pneumatics/hvac/cabin-mid-target ge 60
			</test>
		</switch>
		
		<switch name="/systems/pneumatics/hvac/cabin-aft-target-switched">
			<default value="/systems/pneumatics/hvac/cabin-aft-temp"/>
			<test value="/systems/pneumatics/hvac/cabin-aft-target">
				/systems/pneumatics/hvac/cabin-aft-target ge 60
			</test>
		</switch>
		
		<switch name="/systems/pneumatics/hvac/cargo-fwd-target-switched">
			<default value="/systems/pneumatics/hvac/cargo-fwd-temp"/>
			<test value="/systems/pneumatics/hvac/cargo-fwd-target">
				/systems/pneumatics/hvac/cargo-fwd-target ge 35
			</test>
		</switch>
		
		<switch name="/systems/pneumatics/hvac/cargo-aft-target-switched">
			<default value="/systems/pneumatics/hvac/cargo-aft-temp"/>
			<test value="/systems/pneumatics/hvac/cargo-aft-target">
				/systems/pneumatics/hvac/cargo-aft-target ge 35
			</test>
		</switch>
		
		<!-- Target Temperature Errors -->
		<summer name="/systems/pneumatics/hvac/cockpit-error">
			<input>/systems/pneumatics/hvac/cockpit-target-switched</input>
			<input>-/systems/pneumatics/hvac/cockpit-temp</input>
		</summer>
		
		<summer name="/systems/pneumatics/hvac/cabin-fwd-error">
			<input>/systems/pneumatics/hvac/cabin-fwd-target-switched</input>
			<input>-/systems/pneumatics/hvac/cabin-fwd-temp</input>
		</summer>
		
		<summer name="/systems/pneumatics/hvac/cabin-mid-error">
			<input>/systems/pneumatics/hvac/cabin-mid-target-switched</input>
			<input>-/systems/pneumatics/hvac/cabin-mid-temp</input>
		</summer>
		
		<summer name="/systems/pneumatics/hvac/cabin-aft-error">
			<input>/systems/pneumatics/hvac/cabin-aft-target-switched</input>
			<input>-/systems/pneumatics/hvac/cabin-aft-temp</input>
		</summer>
		
		<summer name="/systems/pneumatics/hvac/cargo-fwd-error">
			<input>/systems/pneumatics/hvac/cargo-fwd-target-switched</input>
			<input>-/systems/pneumatics/hvac/cargo-fwd-temp</input>
		</summer>
		
		<summer name="/systems/pneumatics/hvac/cargo-aft-error">
			<input>/systems/pneumatics/hvac/cargo-aft-target-switched</input>
			<input>-/systems/pneumatics/hvac/cargo-aft-temp</input>
		</summer>
		
		<fcs_function name="/systems/pneumatics/hvac/coldest-cabin-error">
			<function>
				<min>
					<property>/systems/pneumatics/hvac/cabin-aft-error</property>
					<property>/systems/pneumatics/hvac/cabin-mid-error</property>
					<property>/systems/pneumatics/hvac/cabin-fwd-error</property>
					<property>/systems/pneumatics/hvac/cockpit-error</property>
				</min>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-temp-target">
			<function>
				<sum>
					<min>
						<property>/systems/pneumatics/hvac/cabin-aft-target-switched</property>
						<property>/systems/pneumatics/hvac/cabin-mid-target-switched</property>
						<property>/systems/pneumatics/hvac/cabin-fwd-target-switched</property>
						<property>/systems/pneumatics/hvac/cockpit-target-switched</property>
					</min>
					<table>
						<independentVar lookup="row">/systems/pneumatics/hvac/coldest-cabin-error</independentVar>
						<tableData>
							-5 -8
							 0 -1
						</tableData>
					</table>
				</sum>
			</function>
		</fcs_function>
		
		<!-- Pack Temperatures -->
		<fcs_function name="/systems/pneumatics/hvac/pack-1-temp-cmd">
			<function>
				<interpolate1d>
					<property>/systems/pneumatics/pack-1-flow</property>
					<value>0</value><property>propulsion/tat-c</property>
					<value>10</value><property>/systems/pneumatics/hvac/pack-temp-target</property>
				</interpolate1d>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-1-temp-incr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-1-flow</independentVar>
					<tableData>
						 0  0.1
						10  9.0
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-1-temp-decr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-1-flow</independentVar>
					<tableData>
						 0  0.1
						10  4.0
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<actuator name="/systems/pneumatics/hvac/pack-1-temp-actuator">
			<input>/systems/pneumatics/hvac/pack-1-temp-cmd</input>
			<rate_limit sense="incr">/systems/pneumatics/hvac/pack-1-temp-incr-rate</rate_limit>
			<rate_limit sense="decr">/systems/pneumatics/hvac/pack-1-temp-decr-rate</rate_limit>
		</actuator>
		
		<lag_filter name="/systems/pneumatics/hvac/pack-1-temp">
			<input>/systems/pneumatics/hvac/pack-1-temp-actuator</input>
			<c1>0.4</c1>
		</lag_filter>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-2-temp-cmd">
			<function>
				<interpolate1d>
					<property>/systems/pneumatics/pack-2-flow</property>
					<value>0</value><property>propulsion/tat-c</property>
					<value>10</value><property>/systems/pneumatics/hvac/pack-temp-target</property>
				</interpolate1d>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-2-temp-incr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-2-flow</independentVar>
					<tableData>
						 0  0.1
						10  9.0
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-2-temp-decr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-2-flow</independentVar>
					<tableData>
						 0  0.1
						10  4.0
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<actuator name="/systems/pneumatics/hvac/pack-2-temp-actuator">
			<input>/systems/pneumatics/hvac/pack-2-temp-cmd</input>
			<rate_limit sense="incr">/systems/pneumatics/hvac/pack-2-temp-incr-rate</rate_limit>
			<rate_limit sense="decr">/systems/pneumatics/hvac/pack-2-temp-decr-rate</rate_limit>
		</actuator>
		
		<lag_filter name="/systems/pneumatics/hvac/pack-2-temp">
			<input>/systems/pneumatics/hvac/pack-2-temp-actuator</input>
			<c1>0.4</c1>
		</lag_filter>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-3-temp-cmd">
			<function>
				<interpolate1d>
					<property>/systems/pneumatics/pack-3-flow</property>
					<value>0</value><property>propulsion/tat-c</property>
					<value>10</value><property>/systems/pneumatics/hvac/pack-temp-target</property>
				</interpolate1d>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-3-temp-incr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-3-flow</independentVar>
					<tableData>
						 0  0.1
						10  9.0
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<fcs_function name="/systems/pneumatics/hvac/pack-3-temp-decr-rate">
			<function>
				<table>
					<independentVar lookup="row">/systems/pneumatics/pack-3-flow</independentVar>
					<tableData>
						 0  0.1
						10  4.0
					</tableData>
				</table>
			</function>
		</fcs_function>
		
		<actuator name="/systems/pneumatics/hvac/pack-3-temp-actuator">
			<input>/systems/pneumatics/hvac/pack-3-temp-cmd</input>
			<rate_limit sense="incr">/systems/pneumatics/hvac/pack-3-temp-incr-rate</rate_limit>
			<rate_limit sense="decr">/systems/pneumatics/hvac/pack-3-temp-decr-rate</rate_limit>
		</actuator>
		
		<lag_filter name="/systems/pneumatics/hvac/pack-3-temp">
			<input>/systems/pneumatics/hvac/pack-3-temp-actuator</input>
			<c1>0.4</c1>
		</lag_filter>
		
		<!-- Cabin Temperature -->
		<summer name="/systems/pneumatics/hvac/cockpit-temp-environment-error">
			<input>/systems/pneumatics/hvac/cockpit-temp</input>
			<input>-/environment/temperature-degf</input>
		</summer>
		
		<switch name="/systems/pneumatics/hvac/cockpit-temp-environment-rate">
			<default value="0"/>
			<test value="-0.00045">
				/systems/pneumatics/hvac/cockpit-temp-environment-error gt 0.01
			</test>
			<test value="-0.0003">
				/systems/pneumatics/hvac/cockpit-temp-environment-error lt -0.01
			</test>
		</switch>
		
		<fcs_function name="/systems/pneumatics/hvac/cockpit-temp-calc">
			<function>
				<sum>
					<property>/systems/pneumatics/hvac/cockpit-temp</property>
					<product> <!-- Environment Factor -->
						<property>/systems/pneumatics/hvac/cockpit-temp-environment-error</property>
						<property>/systems/pneumatics/hvac/cockpit-temp-environment-rate</property>
						<property>simulation/channel-dt</property>
					</product>
				</sum>
			</function>
			<output>/systems/pneumatics/hvac/cockpit-temp</output>
			<clipto> <!-- Keep it reasonable -->
				<min>32</min>
				<max>99</max>
			</clipto>
		</fcs_function>
		
		<summer name="/systems/pneumatics/hvac/cabin-fwd-temp-environment-error">
			<input>/systems/pneumatics/hvac/cabin-fwd-temp</input>
			<input>-/environment/temperature-degf</input>
		</summer>
		
		<switch name="/systems/pneumatics/hvac/cabin-fwd-temp-environment-rate">
			<default value="0"/>
			<test value="-0.00045">
				/systems/pneumatics/hvac/cabin-fwd-temp-environment-error gt 0.01
			</test>
			<test value="-0.0003">
				/systems/pneumatics/hvac/cabin-fwd-temp-environment-error lt -0.01
			</test>
		</switch>
		
		<fcs_function name="/systems/pneumatics/hvac/cabin-fwd-temp-calc">
			<function>
				<sum>
					<property>/systems/pneumatics/hvac/cabin-fwd-temp</property>
					<product> <!-- Environment Factor -->
						<property>/systems/pneumatics/hvac/cabin-fwd-temp-environment-error</property>
						<property>/systems/pneumatics/hvac/cabin-fwd-temp-environment-rate</property>
						<property>simulation/channel-dt</property>
					</product>
				</sum>
			</function>
			<output>/systems/pneumatics/hvac/cabin-fwd-temp</output>
			<clipto> <!-- Keep it reasonable -->
				<min>32</min>
				<max>99</max>
			</clipto>
		</fcs_function>
		
		<summer name="/systems/pneumatics/hvac/cabin-mid-temp-environment-error">
			<input>/systems/pneumatics/hvac/cabin-mid-temp</input>
			<input>-/environment/temperature-degf</input>
		</summer>
		
		<switch name="/systems/pneumatics/hvac/cabin-mid-temp-environment-rate">
			<default value="0"/>
			<test value="-0.00045">
				/systems/pneumatics/hvac/cabin-mid-temp-environment-error gt 0.01
			</test>
			<test value="-0.0003">
				/systems/pneumatics/hvac/cabin-mid-temp-environment-error lt -0.01
			</test>
		</switch>
		
		<fcs_function name="/systems/pneumatics/hvac/cabin-mid-temp-calc">
			<function>
				<sum>
					<property>/systems/pneumatics/hvac/cabin-mid-temp</property>
					<product> <!-- Environment Factor -->
						<property>/systems/pneumatics/hvac/cabin-mid-temp-environment-error</property>
						<property>/systems/pneumatics/hvac/cabin-mid-temp-environment-rate</property>
						<property>simulation/channel-dt</property>
					</product>
				</sum>
			</function>
			<output>/systems/pneumatics/hvac/cabin-mid-temp</output>
			<clipto> <!-- Keep it reasonable -->
				<min>32</min>
				<max>99</max>
			</clipto>
		</fcs_function>
		
		<summer name="/systems/pneumatics/hvac/cabin-aft-temp-environment-error">
			<input>/systems/pneumatics/hvac/cabin-aft-temp</input>
			<input>-/environment/temperature-degf</input>
		</summer>
		
		<switch name="/systems/pneumatics/hvac/cabin-aft-temp-environment-rate">
			<default value="0"/>
			<test value="-0.00045">
				/systems/pneumatics/hvac/cabin-aft-temp-environment-error gt 0.01
			</test>
			<test value="-0.0003">
				/systems/pneumatics/hvac/cabin-aft-temp-environment-error lt -0.01
			</test>
		</switch>
		
		<fcs_function name="/systems/pneumatics/hvac/cabin-aft-temp-calc">
			<function>
				<ifthen>
					<eq>
						<property>/options/freighter</property>
						<value>1</value>
					</eq>
					<property>/systems/pneumatics/hvac/cabin-mid-temp-calc</property> <!-- Freighter uses mid/aft combined as cargo -->
					<sum>
						<property>/systems/pneumatics/hvac/cabin-aft-temp</property>
						<product> <!-- Environment Factor -->
							<property>/systems/pneumatics/hvac/cabin-aft-temp-environment-error</property>
							<property>/systems/pneumatics/hvac/cabin-aft-temp-environment-rate</property>
							<property>simulation/channel-dt</property>
						</product>
					</sum>
				</ifthen>
			</function>
			<output>/systems/pneumatics/hvac/cabin-aft-temp</output>
			<clipto> <!-- Keep it reasonable -->
				<min>32</min>
				<max>99</max>
			</clipto>
		</fcs_function>
		
		<summer name="/systems/pneumatics/hvac/cargo-fwd-temp-environment-error">
			<input>/systems/pneumatics/hvac/cargo-fwd-temp</input>
			<input>-/environment/temperature-degf</input>
		</summer>
		
		<switch name="/systems/pneumatics/hvac/cargo-fwd-temp-environment-rate">
			<default value="0"/>
			<test value="-0.00045">
				/systems/pneumatics/hvac/cargo-fwd-temp-environment-error gt 0.01
			</test>
			<test value="-0.0003">
				/systems/pneumatics/hvac/cargo-fwd-temp-environment-error lt -0.01
			</test>
		</switch>
		
		<fcs_function name="/systems/pneumatics/hvac/cargo-fwd-temp-calc">
			<function>
				<sum>
					<property>/systems/pneumatics/hvac/cargo-fwd-temp</property>
					<product> <!-- Environment Factor -->
						<property>/systems/pneumatics/hvac/cargo-fwd-temp-environment-error</property>
						<property>/systems/pneumatics/hvac/cargo-fwd-temp-environment-rate</property>
						<property>simulation/channel-dt</property>
					</product>
				</sum>
			</function>
			<output>/systems/pneumatics/hvac/cargo-fwd-temp</output>
			<clipto> <!-- Keep it reasonable -->
				<min>32</min>
				<max>99</max>
			</clipto>
		</fcs_function>
		
		<summer name="/systems/pneumatics/hvac/cargo-mid-temp-environment-error">
			<input>/systems/pneumatics/hvac/cargo-mid-temp</input>
			<input>-/environment/temperature-degf</input>
		</summer>
		
		<switch name="/systems/pneumatics/hvac/cargo-mid-temp-environment-rate">
			<default value="0"/>
			<test value="-0.00045">
				/systems/pneumatics/hvac/cargo-mid-temp-environment-error gt 0.01
			</test>
			<test value="-0.0003">
				/systems/pneumatics/hvac/cargo-mid-temp-environment-error lt -0.01
			</test>
		</switch>
		
		<fcs_function name="/systems/pneumatics/hvac/cargo-mid-temp-calc">
			<function>
				<sum>
					<property>/systems/pneumatics/hvac/cargo-mid-temp</property>
					<product> <!-- Environment Factor -->
						<property>/systems/pneumatics/hvac/cargo-mid-temp-environment-error</property>
						<property>/systems/pneumatics/hvac/cargo-mid-temp-environment-rate</property>
						<property>simulation/channel-dt</property>
					</product>
				</sum>
			</function>
			<output>/systems/pneumatics/hvac/cargo-mid-temp</output>
			<clipto> <!-- Keep it reasonable -->
				<min>32</min>
				<max>99</max>
			</clipto>
		</fcs_function>
		
		<summer name="/systems/pneumatics/hvac/cargo-aft-temp-environment-error">
			<input>/systems/pneumatics/hvac/cargo-aft-temp</input>
			<input>-/environment/temperature-degf</input>
		</summer>
		
		<switch name="/systems/pneumatics/hvac/cargo-aft-temp-environment-rate">
			<default value="0"/>
			<test value="-0.00045">
				/systems/pneumatics/hvac/cargo-aft-temp-environment-error gt 0.01
			</test>
			<test value="-0.0003">
				/systems/pneumatics/hvac/cargo-aft-temp-environment-error lt -0.01
			</test>
		</switch>
		
		<fcs_function name="/systems/pneumatics/hvac/cargo-aft-temp-calc">
			<function>
				<sum>
					<property>/systems/pneumatics/hvac/cargo-aft-temp</property>
					<product> <!-- Environment Factor -->
						<property>/systems/pneumatics/hvac/cargo-aft-temp-environment-error</property>
